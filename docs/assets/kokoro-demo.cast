{"version": 2, "width": 100, "height": 28, "timestamp": 1748390400, "env": {"TERM": "xterm-256color", "SHELL": "/bin/zsh"}, "title": "kokoro-speakd daemon + client demo"}
[0.0, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[0.7, "o", "kokoro-speakd --help\r\n"]
[1.0, "o", "\u001b[38;5;183mkokoro-speakd\u001b[0m \u2014 persistent Kokoro TTS daemon over a Unix socket.\r\n\r\n\u001b[38;5;152mUSAGE\u001b[0m\r\n  kokoro-speakd [flags]\r\n\r\n\u001b[38;5;152mFLAGS\u001b[0m\r\n  --socket <path>      Unix socket path (env: KOKORO_SPEAKD_SOCKET)\r\n                       default: ~/.cache/claude-code-tts/kokoro-speakd.sock\r\n  --log <path>         Log file path (env: KOKORO_SPEAKD_LOG)\r\n  --voice <id>         Default voice (env: KOKORO_DEFAULT_VOICE, default: af_sky)\r\n  --lang <code>        Default lang code (env: KOKORO_DEFAULT_LANG, default: a)\r\n  -h, --help           Show help\r\n\r\n\u001b[38;5;152mPROTOCOL\u001b[0m\r\n  Line-delimited JSON over Unix socket. One request per connection.\r\n  Actions: speak (preempts in-flight), interrupt, ping.\r\n\r\n"]
[3.2, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[3.5, "o", "kokoro-speakd &\r\n"]
[3.8, "o", "[1] 18342\r\n"]
[4.0, "o", "\u001b[38;5;215mwarmup\u001b[0m  loading en_core_web_sm + Kokoro-82M weights\u2026\r\n"]
[9.2, "o", "\u001b[38;5;120mready\u001b[0m   socket=~/.cache/claude-code-tts/kokoro-speakd.sock  voice=af_sky  lang=a  warm=5.4s\r\n"]
[10.6, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[10.9, "o", "kokoro-speak ping\r\n"]
[11.1, "o", "\u001b[38;5;120mpong\u001b[0m  ready=true\r\n"]
[12.0, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[12.3, "o", "echo 'Hello from Kokoro.' | kokoro-speak\r\n"]
[12.6, "o", "\u001b[38;5;120mqueued\u001b[0m  id=42  voice=af_sky  lang=a  chars=18  latency=412ms\r\n"]
[14.0, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[14.3, "o", "kokoro-speak < notes/release-summary.md\r\n"]
[14.6, "o", "\u001b[38;5;120mqueued\u001b[0m  id=43  voice=af_sky  lang=a  chars=4612  latency=458ms  source=markdown.strip\r\n"]
[16.2, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[16.5, "o", "kokoro-speak interrupt\r\n"]
[16.7, "o", "\u001b[38;5;120mok\u001b[0m  cancelled=43\r\n"]
[17.6, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[18.0, "o", "exit\r\n"]
